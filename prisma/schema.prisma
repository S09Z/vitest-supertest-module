generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  empId       Int       @id @map("emp_id")
  empName     String?   @map("emp_name") @db.VarChar(100)
  department  String?   @db.VarChar(50)
  designation String?   @db.VarChar(50)
  hireDate    DateTime? @map("hire_date") @db.Date
  salary      Decimal?  @db.Decimal(12, 2)

  @@map("employees")
}

model Customer {
  customerId Int     @id @map("customer_id")
  fullName   String? @map("full_name") @db.VarChar(100)
  email      String? @unique @db.VarChar(100)
  phone      String? @db.VarChar(20)
  city       String? @db.VarChar(50)
  country    String? @db.VarChar(50)
  orders     Order[]

  @@map("customers")
}

model Product {
  productId     Int         @id @map("product_id")
  productName   String?     @map("product_name") @db.VarChar(150)
  category      String?     @db.VarChar(50)
  brand         String?     @db.VarChar(50)
  unitPrice     Decimal?    @map("unit_price") @db.Decimal(10, 2)
  stockQuantity Int?        @map("stock_quantity")
  orderItems    OrderItem[]

  @@map("products")
}

model Order {
  orderId         Int         @id @map("order_id")
  customerId      Int?        @map("customer_id")
  orderDate       DateTime?   @map("order_date")
  status          String?     @db.VarChar(20)
  shippingCity    String?     @map("shipping_city") @db.VarChar(50)
  shippingCountry String?     @map("shipping_country") @db.VarChar(50)
  customer        Customer?   @relation(fields: [customerId], references: [customerId])
  orderItems      OrderItem[]
  payments        Payment[]

  @@map("orders")
}

model OrderItem {
  orderItemId Int      @id @map("order_item_id")
  orderId     Int?     @map("order_id")
  productId   Int?     @map("product_id")
  quantity    Int?
  unitPrice   Decimal? @map("unit_price") @db.Decimal(10, 2)
  order       Order?   @relation(fields: [orderId], references: [orderId])
  product     Product? @relation(fields: [productId], references: [productId])

  @@map("order_items")
}

model Payment {
  paymentId   Int       @id @map("payment_id")
  orderId     Int?      @map("order_id")
  paymentDate DateTime? @map("payment_date")
  amount      Decimal?  @db.Decimal(12, 2)
  method      String?   @db.VarChar(20)
  status      String?   @db.VarChar(20)
  order       Order?    @relation(fields: [orderId], references: [orderId])

  @@map("payments")
}
